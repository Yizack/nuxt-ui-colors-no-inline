{
  "name": "nuxt-ui-colors-no-inline",
  "version": "0.0.1",
  "description": "Nuxt module that ensures nuxt-ui-colors CSS generated by Nuxt UI respects the Nuxt inlineStyles config when disabled for production builds.",
  "keywords": [
    "nuxt",
    "nuxt-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yizack/nuxt-ui-colors-no-inline.git"
  },
  "homepage": "https://github.com/Yizack/nuxt-ui-colors-no-inline",
  "author": {
    "name": "Yizack Rangel",
    "email": "yizackr@gmail.com",
    "url": "https://yizack.com"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt-module-build build",
    "prepack": "pnpm build",
    "dev": "nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "pnpm lint && pnpm build && pnpm test && changelogen --release && git push --follow-tags",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --reporter=verbose",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc -b --noEmit",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.1",
    "@nuxt/ui": "^4.5.1",
    "defu": "^6.1.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.3",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "^25.4.0",
    "changelogen": "^0.6.2",
    "eslint": "^10.0.3",
    "nuxt": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "pnpm@10.32.0"
}
